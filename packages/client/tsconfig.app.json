{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "references": [{ "path": "../domain" }],
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": [],
    "paths": {
      "@/*": ["./src/*"],
      "@app/domain/*": ["../domain/src/*.js"]
    }
  }
}
