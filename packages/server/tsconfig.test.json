{
  "extends": "../../tsconfig.base.json",
  "include": ["test", "src/**/*.test.ts", "src/**/*.d.ts"],
  "references": [{ "path": "tsconfig.src.json" }],
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": ".tsbuildinfo/test.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@app/domain/*": ["../domain/src/*.js"]
    }
  }
}
